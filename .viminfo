"2	CHAR	0
	################################################
	docker pull ros:humble
	
	docker run -it --network=host -d -v=/dev:/dev -v /tmp/.X11-unix:/tmp/.X11-unix --name humble -e DISPLAY=${DISPLAY} --restart=always ros:humble /bin/bash 
	#进入容器
	docker exec -it 02c484c7d546 /bin/bash
	
	useradd -m -s /bin/bash ubuntu
	passwd ubuntu
	usermod -aG sudo ubuntu
	
	#进入ubuntu用户，切换到主目录
	docker exec -it -u ubuntu -w /home/ubuntu 02c484c7d546 /bin/bash
	
	sudo apt-get update -y && sudo apt-get upgrade -y
	sudo apt-get install vim -y
	sudo apt-get install ros-humble-desktop -y
